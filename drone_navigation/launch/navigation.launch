<launch>
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_laser" args="0 0 0 0 0 0 base_link hokuyo_sensor_link 100" />
  
  <node pkg="tf" type="static_transform_publisher" name="odom_to_base_link_broadcaster" args="0 0 0 0 0 0 odom base_link 100" />

  <node name="map_server" pkg="map_server" type="map_server" args="$(find drone_navigation)/maps/playpen_map.yaml" />

  <arg name="config_dir" value="$(find drone_navigation)/config" />
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <param name="use_sim_time" value="true" />
    <param name="global_costmap/global_frame" value="odom" />
    <param name="local_costmap/global_frame" value="odom" />
    <param name="global_costmap/robot_base_frame" value="base_link" />
    <param name="local_costmap/robot_base_frame" value="base_link" />
    <remap from="cmd_vel" to="/cmd_vel_raw" />
  </node>

  <node pkg="drone_navigation" type="cmd_vel_to_stamped.py" name="cmd_vel_converter" output="screen" />
</launch>